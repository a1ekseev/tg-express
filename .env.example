# Sentry (optional)
APP_SENTRY_DSN=

# Logging
APP_LOG_LEVEL=INFO

# Telegram
APP_TG_BOT_TOKEN=123456:ABC-DEF
APP_TG_PROXY_URL=

# Express (pybotx)
APP_EXPRESS_BOT_ID=00000000-0000-0000-0000-000000000000
APP_EXPRESS_CTS_URL=https://express.example.com
APP_EXPRESS_SECRET_KEY=secret

# Express send behavior
APP_EXPRESS_WAIT_CALLBACK=false
# Prefix for Express group chat names (e.g. "[TG] ")
APP_EXPRESS_GROUP_PREFIX=[T<->E Nomapay]
# Auto-approve channels (create Express chat automatically on first TG message)
APP_AUTO_APPROVE_CHANNELS=false


# PostgreSQL
APP_DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/tg_express

# S3 / Minio
APP_S3_ENDPOINT_URL=http://minio:9000
APP_S3_ACCESS_KEY=minioadmin
APP_S3_SECRET_KEY=minioadmin
APP_S3_BUCKET=tg-express-files
APP_S3_FILE_TTL_DAYS=

# File download
APP_FILE_DOWNLOAD_BASE_URL=http://localhost:8000

# Express admin HUIDs (JSON array of UUIDs, added to every new Express chat as admins)
APP_EXPRESS_ADMIN_HUIDS=[]

# System Channel (Express)
APP_EXPRESS_SYSTEM_CHANNEL_ID=

# Admin auth
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=changeme
APP_JWT_SECRET_KEY=changeme-jwt-secret

# Retry
APP_RETRY_MAX_ATTEMPTS=3
APP_RETRY_BASE_DELAY=1.0
APP_RETRY_MAX_DELAY=30.0
